{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/sankarshanmukhopadhyay/trust-infrastructure-schemas/v0.11.0/delegation/delegation-lineage-verification.schema.json",
  "title": "Delegation Lineage Verification",
  "type": "object",
  "required": [
    "verified_at",
    "verifier",
    "checks",
    "result"
  ],
  "properties": {
    "verified_at": {
      "type": "string",
      "format": "date-time"
    },
    "verifier": {
      "$ref": "#/$defs/artifactReference"
    },
    "checks": {
      "type": "object",
      "required": [
        "principal_continuity",
        "lineage_completeness",
        "scope_attenuation",
        "transaction_binding",
        "status_freshness"
      ],
      "properties": {
        "principal_continuity": {
          "type": "string",
          "enum": [
            "pass",
            "fail",
            "not-applicable"
          ]
        },
        "lineage_completeness": {
          "type": "string",
          "enum": [
            "pass",
            "fail",
            "not-applicable"
          ]
        },
        "scope_attenuation": {
          "type": "string",
          "enum": [
            "pass",
            "fail",
            "not-applicable"
          ]
        },
        "transaction_binding": {
          "type": "string",
          "enum": [
            "pass",
            "fail",
            "not-applicable"
          ]
        },
        "intent_binding": {
          "type": "string",
          "enum": [
            "pass",
            "fail",
            "not-applicable"
          ]
        },
        "status_freshness": {
          "type": "string",
          "enum": [
            "pass",
            "fail",
            "not-applicable"
          ]
        },
        "domain_transition": {
          "type": "string",
          "enum": [
            "pass",
            "fail",
            "not-applicable"
          ]
        },
        "aggregate_authority": {
          "type": "string",
          "enum": [
            "pass",
            "fail",
            "not-applicable"
          ]
        },
        "revocation_propagation": {
          "type": "string",
          "enum": [
            "pass",
            "fail",
            "not-applicable"
          ]
        }
      },
      "additionalProperties": false
    },
    "result": {
      "type": "string",
      "enum": [
        "pass",
        "fail",
        "indeterminate"
      ]
    },
    "evidence": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifactReference"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "artifactReference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "uri"
      ],
      "properties": {
        "uri": {
          "type": "string",
          "format": "uri"
        },
        "media_type": {
          "type": "string"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-fA-F0-9]{64}$"
        },
        "issued_at": {
          "type": "string",
          "format": "date-time"
        },
        "fresh_until": {
          "type": "string",
          "format": "date-time"
        },
        "schema_uri": {
          "type": "string",
          "format": "uri"
        },
        "role": {
          "type": "string",
          "enum": [
            "declaration",
            "evidence",
            "evaluation",
            "policy",
            "binding",
            "decision",
            "receipt",
            "other"
          ]
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
