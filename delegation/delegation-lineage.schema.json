{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/sankarshanmukhopadhyay/trust-infrastructure-schemas/v0.11.0/delegation/delegation-lineage.schema.json",
  "title": "Delegation Lineage",
  "description": "Portable evidence contract for ordered or fan-out delegated authority with principal continuity, scope attenuation, domain transitions, and revocation semantics.",
  "type": "object",
  "required": [
    "lineage_id",
    "originating_principal",
    "transaction_id",
    "topology",
    "hops",
    "chain_verification"
  ],
  "properties": {
    "lineage_id": {
      "type": "string",
      "minLength": 1
    },
    "originating_principal": {
      "$ref": "#/$defs/artifactReference"
    },
    "original_intent": {
      "$ref": "#/$defs/artifactReference"
    },
    "transaction_id": {
      "type": "string",
      "minLength": 1
    },
    "topology": {
      "type": "string",
      "enum": [
        "linear",
        "fan-out",
        "convergent"
      ]
    },
    "hops": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/hop"
      }
    },
    "domain_transitions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/domainTransition"
      }
    },
    "branches": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/branch"
      }
    },
    "convergences": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/convergence"
      }
    },
    "revocation": {
      "$ref": "#/$defs/revocation"
    },
    "chain_verification": {
      "$ref": "#/$defs/lineageVerification"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "topology": {
            "enum": [
              "fan-out",
              "convergent"
            ]
          }
        }
      },
      "then": {
        "required": [
          "branches"
        ]
      }
    }
  ],
  "$defs": {
    "hop": {
      "type": "object",
      "required": [
        "hop_id",
        "delegator",
        "actor",
        "scope_received",
        "scope_granted",
        "attenuation_result",
        "trust_domain",
        "status"
      ],
      "properties": {
        "hop_id": {
          "type": "string"
        },
        "parent_hop_id": {
          "type": "string"
        },
        "delegator": {
          "$ref": "#/$defs/artifactReference"
        },
        "actor": {
          "$ref": "#/$defs/artifactReference"
        },
        "scope_received": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "scope_granted": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "attenuation_result": {
          "type": "string",
          "enum": [
            "pass",
            "fail",
            "not-applicable"
          ]
        },
        "mandate": {
          "$ref": "#/$defs/artifactReference"
        },
        "trust_domain": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "active",
            "suspended",
            "revoked",
            "expired"
          ]
        },
        "valid_from": {
          "type": "string",
          "format": "date-time"
        },
        "valid_until": {
          "type": "string",
          "format": "date-time"
        },
        "status_evidence": {
          "$ref": "#/$defs/artifactReference"
        },
        "verification_receipt": {
          "$ref": "#/$defs/artifactReference"
        }
      },
      "additionalProperties": false
    },
    "domainTransition": {
      "type": "object",
      "required": [
        "from",
        "to",
        "scope_mapping_evidence"
      ],
      "properties": {
        "from": {
          "type": "string"
        },
        "to": {
          "type": "string"
        },
        "scope_mapping_evidence": {
          "$ref": "#/$defs/artifactReference"
        },
        "result": {
          "type": "string",
          "enum": [
            "pass",
            "fail"
          ]
        }
      },
      "additionalProperties": false
    },
    "branch": {
      "type": "object",
      "required": [
        "branch_id",
        "root_hop_id",
        "terminal_hop_ids"
      ],
      "properties": {
        "branch_id": {
          "type": "string"
        },
        "root_hop_id": {
          "type": "string"
        },
        "terminal_hop_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        }
      },
      "additionalProperties": false
    },
    "convergence": {
      "type": "object",
      "required": [
        "convergence_id",
        "branch_ids",
        "aggregate_scope_result"
      ],
      "properties": {
        "convergence_id": {
          "type": "string"
        },
        "branch_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 2
        },
        "aggregate_scope_result": {
          "type": "string",
          "enum": [
            "pass",
            "fail"
          ]
        },
        "effect_reference": {
          "$ref": "#/$defs/artifactReference"
        }
      },
      "additionalProperties": false
    },
    "revocation": {
      "type": "object",
      "properties": {
        "preventive": {
          "type": "string"
        },
        "interruption": {
          "type": "string"
        },
        "compensation": {
          "type": "string"
        },
        "propagation_result": {
          "type": "string",
          "enum": [
            "pass",
            "fail",
            "not-tested"
          ]
        }
      },
      "additionalProperties": false
    },
    "artifactReference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "uri"
      ],
      "properties": {
        "uri": {
          "type": "string",
          "format": "uri"
        },
        "media_type": {
          "type": "string"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-fA-F0-9]{64}$"
        },
        "issued_at": {
          "type": "string",
          "format": "date-time"
        },
        "fresh_until": {
          "type": "string",
          "format": "date-time"
        },
        "schema_uri": {
          "type": "string",
          "format": "uri"
        },
        "role": {
          "type": "string",
          "enum": [
            "declaration",
            "evidence",
            "evaluation",
            "policy",
            "binding",
            "decision",
            "receipt",
            "other"
          ]
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "lineageVerification": {
      "type": "object",
      "required": [
        "verified_at",
        "verifier",
        "checks",
        "result"
      ],
      "properties": {
        "verified_at": {
          "type": "string",
          "format": "date-time"
        },
        "verifier": {
          "$ref": "#/$defs/artifactReference"
        },
        "checks": {
          "type": "object",
          "required": [
            "principal_continuity",
            "lineage_completeness",
            "scope_attenuation",
            "transaction_binding",
            "status_freshness"
          ],
          "properties": {
            "principal_continuity": {
              "type": "string",
              "enum": [
                "pass",
                "fail",
                "not-applicable"
              ]
            },
            "lineage_completeness": {
              "type": "string",
              "enum": [
                "pass",
                "fail",
                "not-applicable"
              ]
            },
            "scope_attenuation": {
              "type": "string",
              "enum": [
                "pass",
                "fail",
                "not-applicable"
              ]
            },
            "transaction_binding": {
              "type": "string",
              "enum": [
                "pass",
                "fail",
                "not-applicable"
              ]
            },
            "intent_binding": {
              "type": "string",
              "enum": [
                "pass",
                "fail",
                "not-applicable"
              ]
            },
            "status_freshness": {
              "type": "string",
              "enum": [
                "pass",
                "fail",
                "not-applicable"
              ]
            },
            "domain_transition": {
              "type": "string",
              "enum": [
                "pass",
                "fail",
                "not-applicable"
              ]
            },
            "aggregate_authority": {
              "type": "string",
              "enum": [
                "pass",
                "fail",
                "not-applicable"
              ]
            },
            "revocation_propagation": {
              "type": "string",
              "enum": [
                "pass",
                "fail",
                "not-applicable"
              ]
            }
          },
          "additionalProperties": false
        },
        "result": {
          "type": "string",
          "enum": [
            "pass",
            "fail",
            "indeterminate"
          ]
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifactReference"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
