{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/sankarshanmukhopadhyay/trust-infrastructure-schemas/v0.8.0/common/artifact-reference.schema.json",
  "title": "Artifact Reference",
  "description": "Reusable reference object for declarations, evidence bundles, evaluation outputs, policies, and related trust artifacts.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "uri"
  ],
  "properties": {
    "uri": {
      "type": "string",
      "format": "uri"
    },
    "media_type": {
      "type": "string"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{64}$"
    },
    "issued_at": {
      "type": "string",
      "format": "date-time"
    },
    "fresh_until": {
      "type": "string",
      "format": "date-time"
    },
    "schema_uri": {
      "type": "string",
      "format": "uri"
    },
    "role": {
      "type": "string",
      "enum": [
        "declaration",
        "evidence",
        "evaluation",
        "policy",
        "binding",
        "decision",
        "receipt",
        "other"
      ]
    },
    "notes": {
      "type": "string"
    }
  }
}
