{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/sankarshanmukhopadhyay/trust-infrastructure-schemas/v0.9.0/validation/artifact-coverage.schema.json",
  "title": "Artifact Validation Coverage Manifest",
  "description": "Machine-readable manifest describing which trust artifact families are documented, example-backed, and validated by repository automation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "release",
    "generated_at",
    "artifacts"
  ],
  "properties": {
    "release": {
      "type": "string",
      "pattern": "^v\\d+\\.\\d+\\.\\d+$"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "artifact_id",
          "status",
          "schema",
          "documentation",
          "validated_by"
        ],
        "properties": {
          "artifact_id": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "normative",
              "implemented",
              "experimental",
              "illustrative"
            ]
          },
          "schema": {
            "type": "string",
            "minLength": 1
          },
          "examples": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "documentation": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 1,
            "uniqueItems": true
          },
          "validated_by": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 1,
            "uniqueItems": true
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  }
}
