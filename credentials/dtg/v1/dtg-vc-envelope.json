{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/sankarshanmukhopadhyay/trust-infrastructure-schemas/v0.9.0/credentials/dtg/v1/dtg-vc-envelope.json",
  "title": "DTG Verifiable Credential Envelope Compatibility Profile",
  "description": "W3C Verifiable Credential envelope profile for DTG credentials emitted or consumed by DTG-compatible implementations.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "@context",
    "type",
    "issuer",
    "credentialSubject",
    "proof"
  ],
  "properties": {
    "@context": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "contains": {
        "enum": [
          "https://www.w3.org/ns/credentials/v2",
          "https://www.w3.org/2018/credentials/v1"
        ]
      }
    },
    "id": {
      "type": "string"
    },
    "type": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "string"
      },
      "contains": {
        "const": "DTGCredential"
      }
    },
    "issuer": {
      "type": [
        "string",
        "object"
      ],
      "description": "DID string or issuer object."
    },
    "issuanceDate": {
      "type": "string",
      "format": "date-time"
    },
    "expirationDate": {
      "type": "string",
      "format": "date-time"
    },
    "validFrom": {
      "type": "string",
      "format": "date-time"
    },
    "validUntil": {
      "type": "string",
      "format": "date-time"
    },
    "credentialSubject": {
      "type": "object",
      "description": "DTG credential subject. The upstream implementation accepts at least an id-bearing subject, while TIS overlays may constrain domain fields more strongly.",
      "additionalProperties": true,
      "required": [
        "id"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^did:[a-z0-9]+:[A-Za-z0-9.\\-_:%]+$"
        },
        "member": {
          "type": "string",
          "pattern": "^did:[a-z0-9]+:[A-Za-z0-9.\\-_:%]+$"
        },
        "memberOf": {
          "type": "string",
          "pattern": "^did:[a-z0-9]+:[A-Za-z0-9.\\-_:%]+$"
        },
        "relationshipTo": {
          "type": "string",
          "pattern": "^did:[a-z0-9]+:[A-Za-z0-9.\\-_:%]+$"
        },
        "relationshipType": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "digest": {
          "type": "string"
        },
        "witnessContext": {
          "type": "object",
          "additionalProperties": true
        },
        "endorsement": {
          "type": [
            "object",
            "string"
          ],
          "additionalProperties": true
        }
      }
    },
    "proof": {
      "type": "object",
      "description": "Proof metadata for Data Integrity or linked-data proof verification.",
      "additionalProperties": true,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string"
        },
        "cryptosuite": {
          "type": "string"
        },
        "created": {
          "type": "string",
          "format": "date-time"
        },
        "verificationMethod": {
          "type": "string"
        },
        "proofPurpose": {
          "type": "string"
        },
        "proofValue": {
          "type": "string"
        },
        "jws": {
          "type": "string"
        }
      }
    },
    "credentialStatus": {
      "type": "object",
      "additionalProperties": true
    },
    "termsOfUse": {
      "type": [
        "object",
        "array"
      ],
      "additionalProperties": true
    },
    "evidence": {
      "type": [
        "object",
        "array",
        "string"
      ],
      "additionalProperties": true
    }
  },
  "anyOf": [
    {
      "required": [
        "validFrom"
      ]
    },
    {
      "required": [
        "issuanceDate"
      ]
    }
  ],
  "oneOf": [
    {
      "properties": {
        "type": {
          "contains": {
            "const": "MembershipCredential"
          }
        }
      }
    },
    {
      "properties": {
        "type": {
          "contains": {
            "const": "RelationshipCredential"
          }
        }
      }
    },
    {
      "properties": {
        "type": {
          "contains": {
            "const": "InvitationCredential"
          }
        }
      }
    },
    {
      "properties": {
        "type": {
          "contains": {
            "const": "PersonaCredential"
          }
        }
      }
    },
    {
      "properties": {
        "type": {
          "contains": {
            "const": "EndorsementCredential"
          }
        }
      }
    },
    {
      "properties": {
        "type": {
          "contains": {
            "const": "WitnessCredential"
          }
        }
      }
    },
    {
      "properties": {
        "type": {
          "contains": {
            "const": "RCardCredential"
          }
        }
      }
    }
  ]
}
