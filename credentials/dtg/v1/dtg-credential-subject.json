{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/sankarshanmukhopadhyay/trust-infrastructure-schemas/v0.9.0/credentials/dtg/v1/dtg-credential-subject.json",
  "title": "DTG Credential Subject Compatibility Profile",
  "description": "Reusable DTG credentialSubject profile aligned to the upstream DTG credential implementation while allowing TIS semantic overlays.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "id"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^did:[a-z0-9]+:[A-Za-z0-9.\\-_:%]+$"
    },
    "member": {
      "type": "string",
      "pattern": "^did:[a-z0-9]+:[A-Za-z0-9.\\-_:%]+$"
    },
    "memberOf": {
      "type": "string",
      "pattern": "^did:[a-z0-9]+:[A-Za-z0-9.\\-_:%]+$"
    },
    "relationshipTo": {
      "type": "string",
      "pattern": "^did:[a-z0-9]+:[A-Za-z0-9.\\-_:%]+$"
    },
    "relationshipType": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "digest": {
      "type": "string"
    },
    "witnessContext": {
      "type": "object",
      "additionalProperties": true
    },
    "endorsement": {
      "type": [
        "object",
        "string"
      ],
      "additionalProperties": true
    }
  }
}
