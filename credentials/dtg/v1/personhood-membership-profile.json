{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/sankarshanmukhopadhyay/trust-infrastructure-schemas/v0.9.0/credentials/dtg/v1/personhood-membership-profile.json",
  "title": "DTG Personhood Membership Overlay",
  "description": "Overlay profile for membership credentials that include PersonhoodCredential semantics in the VC type array.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "member",
    "memberOf",
    "personhoodAssurance",
    "status",
    "effectiveFrom"
  ],
  "properties": {
    "member": {
      "type": "string",
      "pattern": "^did:[a-z0-9]+:[A-Za-z0-9.\\-_:%]+$"
    },
    "memberOf": {
      "type": "string",
      "pattern": "^did:[a-z0-9]+:[A-Za-z0-9.\\-_:%]+$"
    },
    "personhoodAssurance": {
      "type": "string",
      "enum": [
        "self-attested",
        "community-attested",
        "vtc-attested",
        "independently-assessed"
      ]
    },
    "proofOfUniqueness": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "suspended",
        "revoked"
      ]
    },
    "effectiveFrom": {
      "type": "string",
      "format": "date-time"
    },
    "effectiveUntil": {
      "type": "string",
      "format": "date-time"
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
