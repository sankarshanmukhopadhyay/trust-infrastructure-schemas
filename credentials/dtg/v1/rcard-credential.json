{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/sankarshanmukhopadhyay/trust-infrastructure-schemas/v0.9.0/credentials/dtg/v1/rcard-credential.json",
  "title": "DTG Relationship Card Credential",
  "description": "Portable relationship card summary used to exchange or publish bounded relationship metadata without exposing the full underlying edge.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "subject",
    "relationshipCardId",
    "relationshipSummaries",
    "issuedAt",
    "privacyMode"
  ],
  "properties": {
    "subject": {
      "type": "string",
      "pattern": "^did:[a-z0-9]+:[A-Za-z0-9.\\-_:%]+$"
    },
    "relationshipCardId": {
      "type": "string"
    },
    "displayName": {
      "type": "string"
    },
    "relationshipSummaries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "relationshipType",
          "counterparty"
        ],
        "properties": {
          "relationshipType": {
            "type": "string"
          },
          "counterparty": {
            "type": "string",
            "pattern": "^did:[a-z0-9]+:[A-Za-z0-9.\\-_:%]+$"
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "suspended",
              "revoked",
              "expired"
            ]
          },
          "evidenceReference": {
            "type": "string"
          }
        }
      }
    },
    "issuedAt": {
      "type": "string",
      "format": "date-time"
    },
    "validUntil": {
      "type": "string",
      "format": "date-time"
    },
    "privacyMode": {
      "type": "string",
      "enum": [
        "public",
        "selective-disclosure",
        "private-reference"
      ]
    }
  }
}
