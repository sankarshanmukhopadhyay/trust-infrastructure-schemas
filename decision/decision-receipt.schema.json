{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/sankarshanmukhopadhyay/trust-infrastructure-schemas/v0.9.0/decision/decision-receipt.schema.json",
  "title": "Trust Decision Receipt",
  "description": "Machine-readable receipt recording a trust decision, the evaluated artifacts, the authority boundary, the policy context, and the resulting relying-party outcome.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "receipt_id",
    "decision_type",
    "subject",
    "decision_maker",
    "policy_reference",
    "evaluated_artifacts",
    "authority_boundary",
    "result",
    "timestamps"
  ],
  "properties": {
    "receipt_id": {
      "type": "string",
      "minLength": 1
    },
    "receipt_version": {
      "type": "string",
      "default": "1.0"
    },
    "decision_type": {
      "type": "string",
      "enum": [
        "accept",
        "reject",
        "defer",
        "escalate",
        "revoke",
        "suspend"
      ]
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "subject_id",
        "subject_type"
      ],
      "properties": {
        "subject_id": {
          "type": "string",
          "minLength": 1
        },
        "subject_type": {
          "type": "string",
          "enum": [
            "entity",
            "agent",
            "issuer",
            "registry",
            "artifact",
            "credential",
            "service",
            "other"
          ]
        },
        "display_name": {
          "type": "string"
        },
        "uri": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "decision_maker": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "role"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "role": {
          "type": "string",
          "enum": [
            "verifier",
            "registry",
            "relying_party",
            "evaluator",
            "auditor",
            "policy_engine",
            "other"
          ]
        },
        "system_version": {
          "type": "string"
        }
      }
    },
    "policy_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "uri"
      ],
      "properties": {
        "uri": {
          "type": "string",
          "format": "uri"
        },
        "policy_id": {
          "type": "string"
        },
        "media_type": {
          "type": "string"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-fA-F0-9]{64}$"
        },
        "profile": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "evaluated_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "uri"
        ],
        "properties": {
          "uri": {
            "type": "string",
            "format": "uri"
          },
          "media_type": {
            "type": "string"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-fA-F0-9]{64}$"
          },
          "issued_at": {
            "type": "string",
            "format": "date-time"
          },
          "fresh_until": {
            "type": "string",
            "format": "date-time"
          },
          "schema_uri": {
            "type": "string",
            "format": "uri"
          },
          "role": {
            "type": "string",
            "enum": [
              "declaration",
              "evidence",
              "evaluation",
              "policy",
              "binding",
              "decision",
              "receipt",
              "other"
            ]
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "authority_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "statement"
      ],
      "properties": {
        "statement": {
          "type": "string",
          "minLength": 10
        },
        "authority_type": {
          "type": "string"
        },
        "authoritative_party": {
          "type": "string"
        },
        "authority_id": {
          "type": "string"
        },
        "delegation_required": {
          "type": "boolean"
        },
        "revocation_actor": {
          "type": "string"
        },
        "revocation_uri": {
          "type": "string",
          "format": "uri"
        },
        "scope": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "relying_party_constraints": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "assurance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "assurance_level": {
          "type": "string",
          "pattern": "^AL[1-4]$"
        },
        "controls_checked": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Z][A-Z0-9]*(?:-[A-Z0-9]+)*-[0-9]{2}$"
          },
          "uniqueItems": true
        },
        "evaluator_uri": {
          "type": "string",
          "format": "uri"
        },
        "evidence_bundle_uri": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "summary"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "passed",
            "failed",
            "deferred",
            "escalated",
            "revoked",
            "suspended"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 10
        },
        "allowed_actions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "prohibited_actions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "conditions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "timestamps": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decided_at"
      ],
      "properties": {
        "decided_at": {
          "type": "string",
          "format": "date-time"
        },
        "valid_until": {
          "type": "string",
          "format": "date-time"
        },
        "evidence_fresh_until": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uri"
      },
      "uniqueItems": true
    },
    "integrity": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "hash_algorithm": {
          "type": "string",
          "enum": [
            "sha256",
            "sha512"
          ]
        },
        "receipt_hash": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64,128}$"
        },
        "signed": {
          "type": "boolean"
        },
        "signature": {
          "type": "string"
        }
      }
    }
  }
}
