{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/sankarshanmukhopadhyay/trust-infrastructure-schemas/v0.10.0/evidence/evidence-bundle-manifest.schema.json",
  "title": "Evidence Bundle Manifest",
  "description": "Reusable manifest for listing evidence artifacts evaluated in a conformance or trust decision flow.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "bundle_id",
    "subject_id",
    "issued_at",
    "artifacts"
  ],
  "properties": {
    "bundle_id": {
      "type": "string",
      "minLength": 1
    },
    "subject_id": {
      "type": "string",
      "minLength": 1
    },
    "issued_at": {
      "type": "string",
      "format": "date-time"
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "uri"
        ],
        "properties": {
          "uri": {
            "type": "string",
            "format": "uri"
          },
          "media_type": {
            "type": "string"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-fA-F0-9]{64}$"
          },
          "issued_at": {
            "type": "string",
            "format": "date-time"
          },
          "fresh_until": {
            "type": "string",
            "format": "date-time"
          },
          "schema_uri": {
            "type": "string",
            "format": "uri"
          },
          "role": {
            "type": "string",
            "enum": [
              "declaration",
              "evidence",
              "evaluation",
              "policy",
              "binding",
              "decision",
              "receipt",
              "other"
            ]
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "authority_boundary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "statement"
      ],
      "properties": {
        "statement": {
          "type": "string",
          "minLength": 10
        }
      }
    },
    "integrity": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "canonicalization": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "method"
          ],
          "properties": {
            "method": {
              "type": "string",
              "enum": [
                "jcs",
                "json-ld-canonicalization",
                "other"
              ]
            },
            "profile_uri": {
              "type": "string",
              "format": "uri"
            }
          }
        },
        "bundle_digest": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "algorithm",
            "value"
          ],
          "properties": {
            "algorithm": {
              "type": "string",
              "enum": [
                "sha256",
                "sha512"
              ]
            },
            "value": {
              "type": "string",
              "pattern": "^[A-Fa-f0-9]{64,128}$"
            }
          }
        },
        "detached_proofs": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "proof_type",
              "proof_uri",
              "verification_method",
              "created"
            ],
            "properties": {
              "proof_type": {
                "type": "string"
              },
              "proof_uri": {
                "type": "string",
                "format": "uri"
              },
              "verification_method": {
                "type": "string"
              },
              "created": {
                "type": "string",
                "format": "date-time"
              }
            }
          },
          "uniqueItems": true
        },
        "signature": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "signed": {
              "type": "boolean"
            },
            "signature_ref": {
              "type": "string",
              "format": "uri"
            },
            "verification_method": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
