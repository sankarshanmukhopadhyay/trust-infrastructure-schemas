{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/sankarshanmukhopadhyay/trust-infrastructure-schemas/v0.5.1/registry/registry.schema.json",
  "title": "Schema Implementer Registry (Simulation)",
  "description": "A non-normative example of how an ecosystem might index implementers and their conformance declarations.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "registry_version",
    "generated_at",
    "entries"
  ],
  "properties": {
    "registry_version": {
      "type": "string"
    },
    "generated_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}T.*Z$"
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "implementer_id",
          "display_name",
          "declaration",
          "assurance_level",
          "controls"
        ],
        "properties": {
          "implementer_id": {
            "type": "string"
          },
          "display_name": {
            "type": "string"
          },
          "declaration": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "url",
              "sha256"
            ],
            "properties": {
              "url": {
                "type": "string"
              },
              "sha256": {
                "type": "string",
                "pattern": "^[a-fA-F0-9]{64}$"
              }
            }
          },
          "assurance_level": {
            "type": "string",
            "pattern": "^AL[1-4]$"
          },
          "control_namespace": {
            "type": "string",
            "description": "Optional identifier namespace for downstream control catalogs, such as SC or ANAGB."
          },
          "controls": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[A-Z][A-Z0-9]*(?:-[A-Z0-9]+)*-[0-9]{2}$"
            }
          },
          "scope": {
            "type": "object",
            "additionalProperties": true
          },
          "oasf": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "publication_profile": {
                "type": "string",
                "format": "uri"
              },
              "evaluation_envelopes": {
                "type": "array",
                "items": {
                  "type": "string",
                  "format": "uri"
                },
                "uniqueItems": true
              },
              "evidence_references": {
                "type": "array",
                "items": {
                  "type": "string",
                  "format": "uri"
                },
                "uniqueItems": true
              },
              "semantic_bindings": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "model",
                    "entity_id"
                  ],
                  "properties": {
                    "model": {
                      "type": "string",
                      "enum": [
                        "TSMM",
                        "ANAB",
                        "DCAS",
                        "OASF",
                        "other"
                      ]
                    },
                    "entity_id": {
                      "type": "string",
                      "minLength": 1
                    },
                    "binding_uri": {
                      "type": "string",
                      "format": "uri"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}