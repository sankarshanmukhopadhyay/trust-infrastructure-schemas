{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/sankarshanmukhopadhyay/trust-infrastructure-schemas/v0.8.0/registry/registry-entry.schema.json",
  "title": "Registry Entry",
  "description": "Reusable schema for a single registry entry referencing declarations, evidence, evaluations, policy artifacts, decision receipts, and authority-boundary metadata.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "implementer_id",
    "display_name",
    "declaration",
    "assurance_level",
    "controls"
  ],
  "properties": {
    "implementer_id": {
      "type": "string"
    },
    "display_name": {
      "type": "string"
    },
    "declaration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "url",
        "sha256"
      ],
      "properties": {
        "url": {
          "type": "string"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-fA-F0-9]{64}$"
        }
      }
    },
    "assurance_level": {
      "type": "string",
      "pattern": "^AL[1-4]$"
    },
    "control_namespace": {
      "type": "string"
    },
    "controls": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Z][A-Z0-9]*(?:-[A-Z0-9]+)*-[0-9]{2}$"
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": true
    },
    "oasf": {
      "type": "object",
      "additionalProperties": true
    },
    "policy_artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "type",
          "reference"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "odrl_policy_reference",
              "other"
            ]
          },
          "reference": {
            "type": "string",
            "format": "uri"
          },
          "schema": {
            "type": "string",
            "format": "uri"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "uri"
        ],
        "properties": {
          "uri": {
            "type": "string",
            "format": "uri"
          },
          "media_type": {
            "type": "string"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-fA-F0-9]{64}$"
          },
          "issued_at": {
            "type": "string",
            "format": "date-time"
          },
          "fresh_until": {
            "type": "string",
            "format": "date-time"
          },
          "schema_uri": {
            "type": "string",
            "format": "uri"
          },
          "role": {
            "type": "string",
            "enum": [
              "declaration",
              "evidence",
              "evaluation",
              "policy",
              "binding",
              "decision",
              "receipt",
              "other"
            ]
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "authority_boundary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "statement"
      ],
      "properties": {
        "statement": {
          "type": "string",
          "minLength": 10
        }
      }
    }
  }
}
