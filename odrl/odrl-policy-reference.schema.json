{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/sankarshanmukhopadhyay/trust-infrastructure-schemas/v0.8.0/odrl/odrl-policy-reference.schema.json",
  "title": "ODRL Policy Reference",
  "description": "Experimental machine-readable carrier for an ODRL policy or stable reference to one.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "policy_id",
    "target",
    "publication_mode"
  ],
  "properties": {
    "policy_id": {
      "type": "string",
      "minLength": 1
    },
    "profile": {
      "type": "string",
      "format": "uri"
    },
    "target": {
      "type": "string"
    },
    "publication_mode": {
      "type": "string",
      "enum": [
        "embedded",
        "by_reference"
      ]
    },
    "policy_uri": {
      "type": "string",
      "format": "uri"
    },
    "policy_hash": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{64}$"
    },
    "enforcement_note": {
      "type": "string"
    },
    "issuer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        }
      }
    },
    "evaluation_artifacts": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uri"
      },
      "uniqueItems": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "publication_mode": {
            "const": "by_reference"
          }
        }
      },
      "then": {
        "required": [
          "policy_uri"
        ]
      }
    }
  ]
}