{
  "$schema": "https://raw.githubusercontent.com/sankarshanmukhopadhyay/trust-infrastructure-schemas/v0.9.0/model/tsmm-artifact-mapping.schema.json",
  "mapping_id": "tis-tsmm-artifact-mapping-v0.8.0",
  "version": "v0.8.0",
  "semantic_model": "TSMM",
  "artifact_contract_layer": "trust-infrastructure-schemas",
  "canonical_layering": {
    "TSMM": "semantic model and cross-ecosystem grammar",
    "TIS": "canonical executable artifact contracts"
  },
  "mappings": [
    {
      "tsmm_concept": "GovernanceAuthority / AuthorityGraph edge",
      "tis_artifact": "Authority Boundary",
      "schema_path": "governance/authority-boundary.schema.json",
      "mapping_strength": "strong",
      "rule": "A TIS authority boundary is an artifact-level projection of TSMM authority topology.",
      "evidence_produced": [
        "bounded authority statement",
        "delegation chain",
        "revocation obligation"
      ]
    },
    {
      "tsmm_concept": "EvidenceArtifact / EvidenceBundle",
      "tis_artifact": "Evidence Bundle Manifest",
      "schema_path": "evidence/evidence-bundle-manifest.schema.json",
      "mapping_strength": "strong",
      "rule": "TIS packages evidence that TSMM assigns governance meaning to.",
      "evidence_produced": [
        "artifact inventory",
        "hash and freshness references",
        "authority context"
      ]
    },
    {
      "tsmm_concept": "Assessment",
      "tis_artifact": "OASF Evaluation Envelope",
      "schema_path": "oasf/oasf-evaluation-envelope.schema.json",
      "mapping_strength": "moderate",
      "rule": "TIS captures verifier evaluation output linked to assurance and evidence.",
      "evidence_produced": [
        "evaluation result",
        "controls checked",
        "semantic bindings"
      ]
    },
    {
      "tsmm_concept": "TrustDecision / Effect",
      "tis_artifact": "Decision Receipt",
      "schema_path": "decision/decision-receipt.schema.json",
      "mapping_strength": "strong",
      "rule": "TIS records policy-bound decision outcomes and admitted/prohibited effects.",
      "evidence_produced": [
        "decision result",
        "allowed actions",
        "prohibited actions",
        "timestamps"
      ]
    },
    {
      "tsmm_concept": "TrustRegistry",
      "tis_artifact": "Registry Entry",
      "schema_path": "registry/registry-entry.schema.json",
      "mapping_strength": "moderate",
      "rule": "TIS publishes discoverable trust state without creating runtime authority.",
      "evidence_produced": [
        "declaration reference",
        "assurance level",
        "artifact chain"
      ]
    },
    {
      "tsmm_concept": "AssuranceProfile",
      "tis_artifact": "Assurance Level",
      "schema_path": "assurance/assurance.schema.json",
      "mapping_strength": "moderate",
      "rule": "TIS AL1-AL4 express assurance rigor; TSMM posture labels remain model-context descriptors.",
      "evidence_produced": [
        "assurance level",
        "control coverage"
      ]
    }
  ],
  "non_equivalence_rules": [
    "Discovery is not authorization.",
    "Agentic is not an assurance level.",
    "Schema-valid is not automatically legitimate.",
    "Registry publication does not grant runtime authority."
  ]
}
