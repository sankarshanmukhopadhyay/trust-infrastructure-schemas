{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/model/trust-artifact-taxonomy.schema.json",
  "title": "Trust Artifact Taxonomy",
  "type": "object",
  "required": ["model", "version", "artifact_classes"],
  "properties": {
    "model": {"type": "string"},
    "version": {"type": "string"},
    "artifact_classes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "description", "artifacts"],
        "properties": {
          "id": {"type": "string"},
          "name": {"type": "string"},
          "description": {"type": "string"},
          "artifacts": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "path"],
              "properties": {
                "name": {"type": "string"},
                "path": {"type": "string"},
                "status": {"type": "string"},
                "notes": {"type": "string"}
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
