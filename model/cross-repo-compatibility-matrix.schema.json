{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/sankarshanmukhopadhyay/trust-infrastructure-schemas/v0.9.0/model/cross-repo-compatibility-matrix.schema.json",
  "title": "Cross-Repo Compatibility Matrix",
  "description": "Machine-readable matrix for tracking TIS alignment with DTG Credentials, OpenVTC, and Verifiable Trust Infrastructure upstream repositories.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "release",
    "reviewed_at",
    "upstreams",
    "mappings",
    "drift_review"
  ],
  "properties": {
    "release": {
      "type": "string"
    },
    "reviewed_at": {
      "type": "string",
      "format": "date-time"
    },
    "upstreams": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "repo",
          "url",
          "tracked_ref",
          "role"
        ],
        "properties": {
          "repo": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "tracked_ref": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "local_archive_reviewed": {
            "type": "string"
          }
        }
      }
    },
    "mappings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "repo",
          "artifact",
          "role",
          "authority_surface",
          "evidence_produced",
          "tis_profile",
          "assurance_implication",
          "validation_status"
        ],
        "properties": {
          "repo": {
            "type": "string"
          },
          "artifact": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "authority_surface": {
            "type": "string"
          },
          "evidence_produced": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "tis_profile": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "assurance_implication": {
            "type": "string"
          },
          "validation_status": {
            "type": "string",
            "enum": [
              "validated-example",
              "documented",
              "monitor-only",
              "gap"
            ]
          }
        }
      }
    },
    "drift_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cadence",
        "signals",
        "required_action"
      ],
      "properties": {
        "cadence": {
          "type": "string"
        },
        "signals": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "required_action": {
          "type": "string"
        }
      }
    }
  }
}
