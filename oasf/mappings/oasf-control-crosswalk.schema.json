{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/sankarshanmukhopadhyay/trust-infrastructure-schemas/main/oasf/mappings/oasf-control-crosswalk.schema.json",
  "title": "OASF Control Crosswalk",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "crosswalk_id",
    "mappings"
  ],
  "properties": {
    "crosswalk_id": {
      "type": "string"
    },
    "source_repositories": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uri"
      }
    },
    "mappings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "oasf_control_id",
          "target_namespace",
          "target_control_id"
        ],
        "properties": {
          "oasf_control_id": {
            "type": "string"
          },
          "target_namespace": {
            "type": "string"
          },
          "target_control_id": {
            "type": "string"
          },
          "target_repo": {
            "type": "string",
            "format": "uri"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  }
}