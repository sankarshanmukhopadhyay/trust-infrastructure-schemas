{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/sankarshanmukhopadhyay/trust-infrastructure-schemas/v0.8.0/oasf/oasf-publication-profile.schema.json",
  "title": "OASF Publication Profile",
  "description": "Canonical shared artifact shape for publishing an OASF-described subject, its declarations, evidence references, semantic bindings, and control namespaces.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "profile_id",
    "subject",
    "declarations",
    "control_namespaces"
  ],
  "properties": {
    "profile_id": {
      "type": "string",
      "minLength": 1
    },
    "profile_version": {
      "type": "string",
      "minLength": 1
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "subject_id",
        "subject_type"
      ],
      "properties": {
        "subject_id": {
          "type": "string",
          "minLength": 1
        },
        "subject_type": {
          "type": "string",
          "enum": [
            "agent",
            "service",
            "registry",
            "implementation",
            "organization",
            "other"
          ]
        },
        "display_name": {
          "type": "string"
        },
        "resolver": {
          "type": "string",
          "format": "uri"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "declarations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "type",
          "uri"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "conformance",
              "implementer",
              "assurance",
              "baseline"
            ]
          },
          "uri": {
            "type": "string",
            "format": "uri"
          },
          "media_type": {
            "type": "string"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-fA-F0-9]{64}$"
          },
          "issued_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "evidence_references": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "kind",
          "uri"
        ],
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "bundle",
              "log",
              "assessment",
              "monitoring",
              "attestation",
              "other"
            ]
          },
          "uri": {
            "type": "string",
            "format": "uri"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-fA-F0-9]{64}$"
          },
          "fresh_until": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "semantic_bindings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "model",
          "entity_id"
        ],
        "properties": {
          "model": {
            "type": "string",
            "enum": [
              "TSMM",
              "ANAB",
              "DCAS",
              "OASF",
              "other"
            ]
          },
          "entity_id": {
            "type": "string",
            "minLength": 1
          },
          "binding_uri": {
            "type": "string",
            "format": "uri"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "control_namespaces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "namespace",
          "controls"
        ],
        "properties": {
          "namespace": {
            "type": "string",
            "minLength": 1
          },
          "controls": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "mapping_ref": {
            "type": "string",
            "format": "uri"
          }
        }
      }
    },
    "trust_anchors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "anchor_type",
          "uri"
        ],
        "properties": {
          "anchor_type": {
            "type": "string",
            "enum": [
              "registry",
              "issuer",
              "federation",
              "keyset",
              "policy",
              "other"
            ]
          },
          "uri": {
            "type": "string",
            "format": "uri"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "authority_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "statement"
      ],
      "properties": {
        "statement": {
          "type": "string",
          "minLength": 10
        },
        "authoritative_party": {
          "type": "string"
        },
        "delegation_required": {
          "type": "boolean"
        },
        "revocation_actor": {
          "type": "string"
        },
        "revocation_uri": {
          "type": "string",
          "format": "uri"
        },
        "scope": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
