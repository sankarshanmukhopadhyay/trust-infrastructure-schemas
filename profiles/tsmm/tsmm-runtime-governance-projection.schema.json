{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/sankarshanmukhopadhyay/trust-infrastructure-schemas/v0.10.0/profiles/tsmm/tsmm-runtime-governance-projection.schema.json",
  "title": "TSMM Runtime Governance Projection",
  "description": "Projection profile mapping a TSMM runtime governance envelope into executable TIS artifact references without redefining TSMM semantics.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "projection_id",
    "tsmm_runtime_governance_ref",
    "actor_ref",
    "requested_effect_ref",
    "trust_boundary_ref",
    "authority_boundary_ref",
    "policy_refs",
    "evidence_bundle_ref",
    "decision_receipt_ref",
    "effect_admission",
    "audit_refs"
  ],
  "properties": {
    "projection_id": {
      "type": "string",
      "minLength": 1
    },
    "projection_version": {
      "type": "string",
      "default": "1.0"
    },
    "tsmm_runtime_governance_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "uri"
      ],
      "properties": {
        "uri": {
          "type": "string",
          "format": "uri"
        },
        "artifact_id": {
          "type": "string"
        },
        "schema_uri": {
          "type": "string",
          "format": "uri"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "media_type": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      },
      "description": "Reference to the TSMM runtime governance envelope."
    },
    "actor_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "uri"
      ],
      "properties": {
        "uri": {
          "type": "string",
          "format": "uri"
        },
        "artifact_id": {
          "type": "string"
        },
        "schema_uri": {
          "type": "string",
          "format": "uri"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "media_type": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      },
      "description": "Reference to actor/entity in TSMM semantic model."
    },
    "requested_effect_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "uri"
      ],
      "properties": {
        "uri": {
          "type": "string",
          "format": "uri"
        },
        "artifact_id": {
          "type": "string"
        },
        "schema_uri": {
          "type": "string",
          "format": "uri"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "media_type": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      },
      "description": "Reference to requested effect modeled by TSMM."
    },
    "trust_boundary_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "uri"
      ],
      "properties": {
        "uri": {
          "type": "string",
          "format": "uri"
        },
        "artifact_id": {
          "type": "string"
        },
        "schema_uri": {
          "type": "string",
          "format": "uri"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "media_type": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      },
      "description": "Reference to TSMM trust boundary."
    },
    "authority_boundary_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "uri"
      ],
      "properties": {
        "uri": {
          "type": "string",
          "format": "uri"
        },
        "artifact_id": {
          "type": "string"
        },
        "schema_uri": {
          "type": "string",
          "format": "uri"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "media_type": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      },
      "description": "Reference to TIS authority boundary projected from TSMM authority basis."
    },
    "delegation_chain_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "uri"
        ],
        "properties": {
          "uri": {
            "type": "string",
            "format": "uri"
          },
          "artifact_id": {
            "type": "string"
          },
          "schema_uri": {
            "type": "string",
            "format": "uri"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[A-Fa-f0-9]{64}$"
          },
          "media_type": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        },
        "description": "Delegation chain artifact reference."
      },
      "uniqueItems": true
    },
    "policy_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "uri"
        ],
        "properties": {
          "uri": {
            "type": "string",
            "format": "uri"
          },
          "artifact_id": {
            "type": "string"
          },
          "schema_uri": {
            "type": "string",
            "format": "uri"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[A-Fa-f0-9]{64}$"
          },
          "media_type": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        },
        "description": "Policy reference."
      },
      "uniqueItems": true
    },
    "evidence_bundle_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "uri"
      ],
      "properties": {
        "uri": {
          "type": "string",
          "format": "uri"
        },
        "artifact_id": {
          "type": "string"
        },
        "schema_uri": {
          "type": "string",
          "format": "uri"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "media_type": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      },
      "description": "Evidence bundle produced for runtime governance evaluation."
    },
    "revocation_check_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "uri"
      ],
      "properties": {
        "uri": {
          "type": "string",
          "format": "uri"
        },
        "artifact_id": {
          "type": "string"
        },
        "schema_uri": {
          "type": "string",
          "format": "uri"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "media_type": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      },
      "description": "Revocation or status check reference."
    },
    "decision_receipt_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "uri"
      ],
      "properties": {
        "uri": {
          "type": "string",
          "format": "uri"
        },
        "artifact_id": {
          "type": "string"
        },
        "schema_uri": {
          "type": "string",
          "format": "uri"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "media_type": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      },
      "description": "Decision receipt reference."
    },
    "effect_admission": {
      "type": "string",
      "enum": [
        "permitted",
        "blocked",
        "queued-for-review",
        "restricted"
      ]
    },
    "audit_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "uri"
        ],
        "properties": {
          "uri": {
            "type": "string",
            "format": "uri"
          },
          "artifact_id": {
            "type": "string"
          },
          "schema_uri": {
            "type": "string",
            "format": "uri"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[A-Fa-f0-9]{64}$"
          },
          "media_type": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        },
        "description": "Audit trail or event reference."
      },
      "uniqueItems": true
    },
    "notes": {
      "type": "string"
    }
  }
}
