{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/sankarshanmukhopadhyay/trust-infrastructure-schemas/v0.10.0/profiles/trust-tasks/trust-task-execution-receipt.schema.json",
  "title": "Trust Task Execution Receipt",
  "description": "Runtime execution receipt that separates TSMM-aligned task lifecycle, decision outcome, effect admission, authority scope, and audit evidence.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "receipt_id",
    "task_ref",
    "actor",
    "subject_ref",
    "authority_context_ref",
    "lifecycle_state",
    "decision_outcome",
    "effect_admission",
    "executed_at",
    "evidence_refs"
  ],
  "properties": {
    "receipt_id": {
      "type": "string",
      "minLength": 1
    },
    "task_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "uri"
      ],
      "properties": {
        "uri": {
          "type": "string",
          "format": "uri"
        },
        "artifact_id": {
          "type": "string"
        },
        "schema_uri": {
          "type": "string",
          "format": "uri"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "media_type": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      },
      "description": "Trust Task reference."
    },
    "transport": {
      "type": "string",
      "enum": [
        "rest",
        "didcomm",
        "internal",
        "cli",
        "other"
      ]
    },
    "actor": {
      "type": "string",
      "pattern": "^did:[a-z0-9]+:[A-Za-z0-9.\\-_%:]+$"
    },
    "subject_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "uri"
      ],
      "properties": {
        "uri": {
          "type": "string",
          "format": "uri"
        },
        "artifact_id": {
          "type": "string"
        },
        "schema_uri": {
          "type": "string",
          "format": "uri"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "media_type": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      },
      "description": "Subject affected by the task."
    },
    "authority_context_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "uri"
      ],
      "properties": {
        "uri": {
          "type": "string",
          "format": "uri"
        },
        "artifact_id": {
          "type": "string"
        },
        "schema_uri": {
          "type": "string",
          "format": "uri"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "media_type": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      },
      "description": "Authority boundary, ACL, or delegation evidence."
    },
    "tsmm_runtime_governance_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "uri"
      ],
      "properties": {
        "uri": {
          "type": "string",
          "format": "uri"
        },
        "artifact_id": {
          "type": "string"
        },
        "schema_uri": {
          "type": "string",
          "format": "uri"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "media_type": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      },
      "description": "TSMM runtime governance envelope reference."
    },
    "request_digest": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "response_digest": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "lifecycle_state": {
      "type": "string",
      "enum": [
        "submitted",
        "working",
        "input-required",
        "auth-required",
        "completed",
        "failed",
        "canceled",
        "rejected"
      ]
    },
    "decision_outcome": {
      "type": "string",
      "enum": [
        "allow",
        "deny",
        "warn",
        "review",
        "downgrade",
        "suspend"
      ]
    },
    "effect_admission": {
      "type": "string",
      "enum": [
        "permitted",
        "blocked",
        "queued-for-review",
        "restricted"
      ]
    },
    "policy_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "uri"
        ],
        "properties": {
          "uri": {
            "type": "string",
            "format": "uri"
          },
          "artifact_id": {
            "type": "string"
          },
          "schema_uri": {
            "type": "string",
            "format": "uri"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[A-Fa-f0-9]{64}$"
          },
          "media_type": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        },
        "description": "Policy reference."
      },
      "uniqueItems": true
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "uri"
        ],
        "properties": {
          "uri": {
            "type": "string",
            "format": "uri"
          },
          "artifact_id": {
            "type": "string"
          },
          "schema_uri": {
            "type": "string",
            "format": "uri"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[A-Fa-f0-9]{64}$"
          },
          "media_type": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        },
        "description": "Evidence artifact reference."
      },
      "uniqueItems": true
    },
    "executed_at": {
      "type": "string",
      "format": "date-time"
    },
    "fresh_until": {
      "type": "string",
      "format": "date-time"
    },
    "audit_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "uri"
        ],
        "properties": {
          "uri": {
            "type": "string",
            "format": "uri"
          },
          "artifact_id": {
            "type": "string"
          },
          "schema_uri": {
            "type": "string",
            "format": "uri"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[A-Fa-f0-9]{64}$"
          },
          "media_type": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        },
        "description": "Audit reference."
      },
      "uniqueItems": true
    }
  }
}
