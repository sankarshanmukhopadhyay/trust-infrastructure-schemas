{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/sankarshanmukhopadhyay/trust-infrastructure-schemas/v0.10.0/profiles/trust-tasks/trust-task-lifecycle-event.schema.json",
  "title": "Trust Task Lifecycle Event",
  "description": "Lifecycle event for a Trust Task using the TSMM-aligned task evidence state vocabulary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "task_id",
    "lifecycle_state",
    "occurred_at",
    "actor"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "lifecycle_state": {
      "type": "string",
      "enum": [
        "submitted",
        "working",
        "input-required",
        "auth-required",
        "completed",
        "failed",
        "canceled",
        "rejected"
      ]
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "actor": {
      "type": "string",
      "pattern": "^did:[a-z0-9]+:[A-Za-z0-9.\\-_%:]+$"
    },
    "reason": {
      "type": "string"
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "uri"
        ],
        "properties": {
          "uri": {
            "type": "string",
            "format": "uri"
          },
          "artifact_id": {
            "type": "string"
          },
          "schema_uri": {
            "type": "string",
            "format": "uri"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[A-Fa-f0-9]{64}$"
          },
          "media_type": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        },
        "description": "Lifecycle evidence reference."
      },
      "uniqueItems": true
    },
    "tsmm_runtime_governance_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "uri"
      ],
      "properties": {
        "uri": {
          "type": "string",
          "format": "uri"
        },
        "artifact_id": {
          "type": "string"
        },
        "schema_uri": {
          "type": "string",
          "format": "uri"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "media_type": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      },
      "description": "TSMM runtime governance envelope reference."
    }
  }
}
