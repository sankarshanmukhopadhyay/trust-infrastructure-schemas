{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/sankarshanmukhopadhyay/trust-infrastructure-schemas/v0.10.0/profiles/trust-tasks/trust-task-reference.schema.json",
  "title": "Trust Task Reference",
  "description": "Stable reference to a Trust Task manifest or implementation used as runtime assurance evidence.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "task_family",
    "task_version",
    "task_uri"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "task_family": {
      "type": "string",
      "enum": [
        "credential-exchange",
        "auth",
        "acl",
        "policy",
        "membership",
        "relationship",
        "status-list",
        "registry-publication",
        "other"
      ]
    },
    "task_version": {
      "type": "string",
      "minLength": 1
    },
    "task_uri": {
      "type": "string",
      "format": "uri"
    },
    "manifest_uri": {
      "type": "string",
      "format": "uri"
    },
    "tsmm_effect_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "uri"
      ],
      "properties": {
        "uri": {
          "type": "string",
          "format": "uri"
        },
        "artifact_id": {
          "type": "string"
        },
        "schema_uri": {
          "type": "string",
          "format": "uri"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "media_type": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      },
      "description": "TSMM requested effect reference."
    },
    "notes": {
      "type": "string"
    }
  }
}
