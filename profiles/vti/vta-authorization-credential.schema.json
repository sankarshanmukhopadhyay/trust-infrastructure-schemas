{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/sankarshanmukhopadhyay/trust-infrastructure-schemas/v0.9.0/profiles/vti/vta-authorization-credential.schema.json",
  "title": "VTI VTA Authorization Credential",
  "description": "Credential profile for delegating or proving bounded authorization to operate against a VTA context.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "credential_id",
    "issuer",
    "holder",
    "vta_did",
    "context_id",
    "permissions",
    "valid_from"
  ],
  "properties": {
    "credential_id": {
      "type": "string"
    },
    "issuer": {
      "type": "string",
      "pattern": "^did:[a-z0-9]+:[A-Za-z0-9.\\-_:%]+$"
    },
    "holder": {
      "type": "string",
      "pattern": "^did:[a-z0-9]+:[A-Za-z0-9.\\-_:%]+$"
    },
    "vta_did": {
      "type": "string",
      "pattern": "^did:[a-z0-9]+:[A-Za-z0-9.\\-_:%]+$"
    },
    "context_id": {
      "type": "string"
    },
    "role": {
      "type": "string"
    },
    "permissions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "valid_from": {
      "type": "string",
      "format": "date-time"
    },
    "valid_until": {
      "type": "string",
      "format": "date-time"
    },
    "revocation_ref": {
      "type": "string"
    },
    "proof_ref": {
      "type": "string"
    }
  }
}
