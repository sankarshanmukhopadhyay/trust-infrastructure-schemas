{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/sankarshanmukhopadhyay/trust-infrastructure-schemas/v0.10.0/profiles/vti/vta-acl-entry.schema.json",
  "title": "VTI VTA ACL Entry",
  "description": "Authorization evidence entry describing VTI implementation role, capability grant, context scope, consumer kind, lifecycle state, and TSMM authority semantics.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "entry_id",
    "subject_did",
    "vta_did",
    "role",
    "capabilities",
    "allowed_contexts",
    "consumer",
    "granted_at",
    "granted_by",
    "status"
  ],
  "properties": {
    "entry_id": {
      "type": "string"
    },
    "subject_did": {
      "type": "string",
      "pattern": "^did:[a-z0-9]+:[A-Za-z0-9.\\-_%:]+$"
    },
    "vta_did": {
      "type": "string",
      "pattern": "^did:[a-z0-9]+:[A-Za-z0-9.\\-_%:]+$"
    },
    "role": {
      "type": "string",
      "enum": [
        "admin",
        "initiator",
        "application",
        "reader",
        "monitor"
      ]
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "vault-read",
          "vault-write",
          "credential-write",
          "proxy-login",
          "fill-release",
          "policy-admin",
          "device-admin",
          "sign",
          "sign-trust-task",
          "key-mint"
        ]
      },
      "uniqueItems": true
    },
    "permissions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true,
      "description": "Deprecated compatibility field. Use capabilities for VTI-aligned enforcement."
    },
    "allowed_contexts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "consumer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "companion",
            "service"
          ]
        },
        "form_factor": {
          "type": "string",
          "enum": [
            "browser",
            "mobile",
            "desktop"
          ]
        },
        "service_kind": {
          "type": "string",
          "enum": [
            "mediator",
            "ai-agent",
            "daemon",
            "api-service",
            "other"
          ]
        }
      }
    },
    "granted_at": {
      "type": "string",
      "format": "date-time"
    },
    "granted_by": {
      "type": "string",
      "pattern": "^did:[a-z0-9]+:[A-Za-z0-9.\\-_%:]+$"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "revoked_at": {
      "type": "string",
      "format": "date-time"
    },
    "suspended_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "suspended",
        "revoked",
        "expired"
      ]
    },
    "version": {
      "type": "string"
    },
    "step_up_required": {
      "type": "boolean"
    },
    "step_up_mode": {
      "type": "string",
      "enum": [
        "none",
        "webauthn",
        "otp",
        "hardware-key",
        "out-of-band",
        "other"
      ]
    },
    "tsmm_authority_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "uri"
      ],
      "properties": {
        "uri": {
          "type": "string",
          "format": "uri"
        },
        "artifact_id": {
          "type": "string"
        },
        "schema_uri": {
          "type": "string",
          "format": "uri"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "media_type": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      },
      "description": "TSMM authority reference."
    },
    "tsmm_role_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "uri"
      ],
      "properties": {
        "uri": {
          "type": "string",
          "format": "uri"
        },
        "artifact_id": {
          "type": "string"
        },
        "schema_uri": {
          "type": "string",
          "format": "uri"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "media_type": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      },
      "description": "TSMM role reference."
    },
    "tsmm_effect_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "uri"
      ],
      "properties": {
        "uri": {
          "type": "string",
          "format": "uri"
        },
        "artifact_id": {
          "type": "string"
        },
        "schema_uri": {
          "type": "string",
          "format": "uri"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "media_type": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      },
      "description": "TSMM effect reference."
    },
    "tsmm_trust_boundary_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "uri"
      ],
      "properties": {
        "uri": {
          "type": "string",
          "format": "uri"
        },
        "artifact_id": {
          "type": "string"
        },
        "schema_uri": {
          "type": "string",
          "format": "uri"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "media_type": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      },
      "description": "TSMM trust boundary reference."
    },
    "tsmm_policy_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "uri"
      ],
      "properties": {
        "uri": {
          "type": "string",
          "format": "uri"
        },
        "artifact_id": {
          "type": "string"
        },
        "schema_uri": {
          "type": "string",
          "format": "uri"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "media_type": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      },
      "description": "TSMM policy reference."
    }
  }
}
