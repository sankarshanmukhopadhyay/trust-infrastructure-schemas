{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/sankarshanmukhopadhyay/trust-infrastructure-schemas/v0.9.0/profiles/vti/vta-acl-entry.schema.json",
  "title": "VTI VTA ACL Entry",
  "description": "Authorization control entry describing subject role, permissions, context scope, and revocation state for a VTA.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "entry_id",
    "subject_did",
    "vta_did",
    "role",
    "permissions",
    "granted_at",
    "granted_by",
    "status"
  ],
  "properties": {
    "entry_id": {
      "type": "string"
    },
    "subject_did": {
      "type": "string",
      "pattern": "^did:[a-z0-9]+:[A-Za-z0-9.\\-_:%]+$"
    },
    "vta_did": {
      "type": "string",
      "pattern": "^did:[a-z0-9]+:[A-Za-z0-9.\\-_:%]+$"
    },
    "role": {
      "type": "string",
      "enum": [
        "admin",
        "operator",
        "issuer",
        "consumer",
        "auditor",
        "maintainer"
      ]
    },
    "permissions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "allowed_contexts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "granted_at": {
      "type": "string",
      "format": "date-time"
    },
    "granted_by": {
      "type": "string",
      "pattern": "^did:[a-z0-9]+:[A-Za-z0-9.\\-_:%]+$"
    },
    "revoked_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "suspended",
        "revoked",
        "expired"
      ]
    }
  }
}
