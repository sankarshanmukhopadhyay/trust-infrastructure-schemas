{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/sankarshanmukhopadhyay/trust-infrastructure-schemas/v0.9.0/profiles/openvtc/openvtc-config-evidence.schema.json",
  "title": "OpenVTC Configuration Evidence",
  "description": "Evidence manifest for OpenVTC public, secured, protected, and private configuration surfaces without disclosing secret values.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "evidence_id",
    "subject_did",
    "config_class",
    "digest",
    "encryption_state",
    "contains_secret_material",
    "captured_at"
  ],
  "properties": {
    "evidence_id": {
      "type": "string"
    },
    "subject_did": {
      "type": "string",
      "pattern": "^did:[a-z0-9]+:[A-Za-z0-9.\\-_:%]+$"
    },
    "config_class": {
      "type": "string",
      "enum": [
        "public",
        "secured",
        "protected",
        "private"
      ]
    },
    "config_path": {
      "type": "string"
    },
    "digest": {
      "type": "string"
    },
    "encryption_state": {
      "type": "string",
      "enum": [
        "plaintext-public",
        "encrypted-at-rest",
        "hardware-protected",
        "redacted"
      ]
    },
    "contains_secret_material": {
      "type": "boolean"
    },
    "captured_at": {
      "type": "string",
      "format": "date-time"
    },
    "access_control_ref": {
      "type": "string"
    }
  }
}
