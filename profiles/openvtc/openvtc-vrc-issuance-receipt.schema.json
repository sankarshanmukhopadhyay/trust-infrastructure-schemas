{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/sankarshanmukhopadhyay/trust-infrastructure-schemas/v0.9.0/profiles/openvtc/openvtc-vrc-issuance-receipt.schema.json",
  "title": "OpenVTC VRC Issuance Receipt",
  "description": "Receipt recording a Verifiable Relationship Credential request, issuance, verification, and storage event.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "receipt_id",
    "relationship_id",
    "issuer_did",
    "holder_did",
    "credential_id",
    "issued_at",
    "verification_result"
  ],
  "properties": {
    "receipt_id": {
      "type": "string"
    },
    "relationship_id": {
      "type": "string"
    },
    "issuer_did": {
      "type": "string",
      "pattern": "^did:[a-z0-9]+:[A-Za-z0-9.\\-_:%]+$"
    },
    "holder_did": {
      "type": "string",
      "pattern": "^did:[a-z0-9]+:[A-Za-z0-9.\\-_:%]+$"
    },
    "subject_did": {
      "type": "string",
      "pattern": "^did:[a-z0-9]+:[A-Za-z0-9.\\-_:%]+$"
    },
    "credential_id": {
      "type": "string"
    },
    "credential_type": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "issued_at": {
      "type": "string",
      "format": "date-time"
    },
    "valid_until": {
      "type": "string",
      "format": "date-time"
    },
    "verification_result": {
      "type": "string",
      "enum": [
        "verified",
        "failed",
        "not_checked"
      ]
    },
    "storage_location": {
      "type": "string"
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
