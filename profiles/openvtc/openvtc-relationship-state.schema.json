{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/sankarshanmukhopadhyay/trust-infrastructure-schemas/v0.9.0/profiles/openvtc/openvtc-relationship-state.schema.json",
  "title": "OpenVTC Relationship State Evidence",
  "description": "Evidence record for OpenVTC relationship request, acceptance, finalization, expiry, rejection, or revocation state.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "relationship_id",
    "requester_did",
    "responder_did",
    "state",
    "state_changed_at"
  ],
  "properties": {
    "relationship_id": {
      "type": "string"
    },
    "requester_did": {
      "type": "string",
      "pattern": "^did:[a-z0-9]+:[A-Za-z0-9.\\-_:%]+$"
    },
    "responder_did": {
      "type": "string",
      "pattern": "^did:[a-z0-9]+:[A-Za-z0-9.\\-_:%]+$"
    },
    "state": {
      "type": "string",
      "enum": [
        "requested",
        "accepted",
        "finalized",
        "rejected",
        "expired",
        "revoked"
      ]
    },
    "state_changed_at": {
      "type": "string",
      "format": "date-time"
    },
    "mediator_did": {
      "type": "string",
      "pattern": "^did:[a-z0-9]+:[A-Za-z0-9.\\-_:%]+$"
    },
    "messages": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "message_id",
          "message_type",
          "timestamp"
        ],
        "properties": {
          "message_id": {
            "type": "string"
          },
          "message_type": {
            "type": "string"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "digest": {
            "type": "string"
          }
        }
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
